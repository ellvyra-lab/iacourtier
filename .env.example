# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored and never committed.

# ---- MailerLite (newsletter / guide download capture) ----
# https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# ---- Supabase (auth, database, history) ----
# https://supabase.com/dashboard -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Settings -> API -> "service_role" key. SERVER-ONLY — never expose this
# to the browser. Used only by the Stripe webhook to update profiles
# without a logged-in user session.
SUPABASE_SERVICE_ROLE_KEY=

# ---- OpenAI (powers every Assistant IA) ----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Stripe (subscriptions) ----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# https://dashboard.stripe.com/webhooks -> add endpoint -> signing secret
STRIPE_WEBHOOK_SECRET=
# https://dashboard.stripe.com/products -> create a recurring price for
# each paid plan, then paste the Price IDs (start with "price_") here.
STRIPE_PRICE_ESSENTIEL=
STRIPE_PRICE_PRO=

# ---- Sentry (error monitoring) ----
# https://sentry.io -> create a Next.js project -> Settings -> Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Only needed for source map upload in CI/production builds — optional.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
